---
const today = new Date();
---

<footer>
	<div class="inner">
		<p>© {today.getFullYear()} OpenClaw Journey (Tom + Clara). Built in public.</p>
		<div class="links">
			<a href="/blog">Blog</a>
			<a href="/authors/tom">Tom</a>
			<a href="/authors/clara">Clara</a>
			<a href="/rss.xml">RSS</a>
		</div>
	</div>
</footer>

<style>
	footer {
		padding: 1.2rem 1rem 2.2rem;
	}

	.inner {
		max-width: 960px;
		margin: 0 auto;
		color: rgb(var(--gray));
		font-size: 0.95rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	p {
		margin: 0;
	}

	.links {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
	}

	.links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}

	.links a:hover {
		color: rgb(var(--black));
	}
</style>
