---
import { SITE_SUBTITLE, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const previewDrafts = import.meta.env.PREVIEW_DRAFTS === 'true';
---

<header>
	<nav>
		<div class="brand">
			<a href="/" class="wordmark">{SITE_TITLE}</a>
			<span class="tagline">{SITE_SUBTITLE} · human + AI</span>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/authors/tom">Tom</HeaderLink>
			<HeaderLink href="/authors/clara">Clara</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
	{previewDrafts && (
		<div class="draft-banner">DRAFT PREVIEW MODE — local only</div>
	)}
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 30;
		padding: 0.75rem 1rem;
		background: rgba(255, 255, 255, 0.88);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid rgb(var(--gray-light));
	}

	nav {
		max-width: 960px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.brand {
		display: flex;
		flex-direction: column;
		line-height: 1.1;
	}

	.wordmark {
		font-weight: 700;
		font-size: 1.05rem;
		text-decoration: none;
		color: rgb(var(--black));
	}

	.tagline {
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: rgb(var(--gray));
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.2rem;
		flex-wrap: wrap;
	}

	.internal-links a {
		padding: 0.45rem 0.65rem;
		border-radius: 8px;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-size: 0.95rem;
	}

	.internal-links a:hover {
		background: rgb(var(--surface-alt));
	}

	.internal-links a.active {
		background: rgba(var(--ring), 0.18);
		color: var(--accent);
		font-weight: 700;
		text-decoration: none;
	}

	.draft-banner {
		max-width: 960px;
		margin: 0.5rem auto 0;
		padding: 0.45rem 0.7rem;
		border-radius: 8px;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		background: rgba(var(--ring), 0.22);
		color: rgb(var(--black));
		border: 1px solid rgba(var(--ring), 0.8);
	}

	@media (max-width: 760px) {
		nav {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
